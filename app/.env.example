APP_NAME="AEGIS MAILING"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev: sqlite suffit. Production cible: pgsql.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=aegis_mailing
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Local dev: database suffit. Production cible: redis.
QUEUE_CONNECTION=database

# Local dev: database suffit. Production cible: redis.
CACHE_STORE=database
# CACHE_PREFIX=

# Redis (optionnel en local, recommandé en production)
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AEGIS Mail Gateway ──────────────────────────────────────
# http  = envoi réel via le service Node mail-gateway (défaut local + production)
# stub  = aucun envoi réel, toujours succès (tests automatisés uniquement)
# Le script scripts/dev.ps1 lance automatiquement le gateway et le worker.
MAIL_GATEWAY_DRIVER=http
MAIL_GATEWAY_BASE_URL=http://127.0.0.1:3001
MAIL_GATEWAY_TIMEOUT=10
MAIL_GATEWAY_SHARED_SECRET=

MAIL_OUTBOUND_QUEUE=mail-outbound
MAIL_SYNC_QUEUE=mail-sync

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
